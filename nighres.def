# Start from the official Debian image
Bootstrap: localimage
From: debian_bookworm.sif
# From: ubuntu_noble.sif

# NOTE Debian bookwork provides Python 3.11

%files
. /nighres
docker/jupyter_notebook_config.py /etc/jupyter/

%environment
export LD_LIBRARY_PATH=/lib/x86_64-linux-gnu:/usr/lib/jvm/temurin-8-jdk-amd64/jre/lib/amd64:/usr/lib/jvm/temurin-8-jdk-amd64/jre/lib/amd64/server
export JAVA_HOME=/usr/lib/jvm/temurin-8-jdk-amd64

%post
# NOTE all this is done as root by default, no need to "su"

export DEBIAN_FRONTEND="noninteractive"

# Install necessary tools and dependencies
apt-get update
apt-get install -y wget gnupg ca-certificates apt-transport-https

# temurin repo provides JDK 1.8
mkdir -p /etc/apt/keyrings
wget -qO - https://packages.adoptium.net/artifactory/api/gpg/key/public | gpg --dearmor | tee /etc/apt/trusted.gpg.d/adoptium.gpg > /dev/null
echo "deb https://packages.adoptium.net/artifactory/deb $(awk -F= '/^VERSION_CODENAME/{print$2}' /etc/os-release) main" | tee /etc/apt/sources.list.d/adoptium.list

apt-get update
apt-get install -y temurin-8-jdk

dpkg-query -L temurin-8-jdk

apt-get install -y --no-install-recommends \
    ca-certificates \
    git \
    build-essential \
    binutils \
    python3 \
    python3-pip \
    python3-dev \
    python3-full \
    libffi-dev
rm -rf /var/lib/apt/lists/*

# Adjust JAVA_HOME if necessary and create a symbolic link to match JCC's expected JDK path
# As of 2025-12-05, JCC works with Java 1.8 and no later
#ENV JAVA_HOME=/usr/lib/jvm/java-17-openjdk-amd64
#RUN ln -s $JAVA_HOME /usr/lib/jvm/temurin-17-jdk-amd64

# Create a venv for nighres

# Install JCC

# Use a venv as Debian won't pip install into systemwide location
mkdir /venvs
python3 -m venv /venvs/nighres
. /venvs/nighres/bin/activate

which python
which python3

python3 -m pip install -U pip wheel setuptools

export   JCC_JDK=/usr/lib/jvm/temurin-8-jdk-amd64
export JAVA_HOME=/usr/lib/jvm/temurin-8-jdk-amd64

# XXX these don't seem to allow the paths to be found at compile time
#     for the JCC build
ldconfig -v /usr/lib/jvm/temurin-8-jdk-amd64/jre/lib/amd64 /usr/lib/jvm/temurin-8-jdk-amd64/jre/lib/amd64/server

# see if those dirs got added
ldconfig -p

# check the cache
echo "Now is: " $(date)
ls -l /etc/ld.so.cache

# apparently, ldconfig is not enough
export JCC_CLFAGS="-shared -fpic"
export JCC_LFLAGS="-L/usr/lib/jvm/temurin-8-jdk-amd64/jre/lib/amd64 \
  -Wl,-rpath,/usr/lib/jvm/temurin-8-jdk-amd64/jre/lib/amd64 \
  -L/usr/lib/jvm/temurin-8-jdk-amd64/jre/lib/amd64/server \
  -Wl,-rpath,/usr/lib/jvm/temurin-8-jdk-amd64/jre/lib/amd64 -ljava -ljvm"

python3 -m pip install jcc

# check jcc lib
# In a functioning environment, the _jcc3 python shared object lib should give
# the following; in particular note libjava.so libjvm.so libverify.so:
# ❯ ldd _jcc3.cpython-311-x86_64-linux-gnu.so
#         linux-vdso.so.1 =>  (0x00007ffcd4f19000)
#         libjava.so => /usr/lib/jvm/java-1.8.0/jre/lib/amd64/libjava.so (0x00007fa94876d000)
#         libjvm.so => /usr/lib/jvm/java-1.8.0/jre/lib/amd64/server/libjvm.so (0x00007fa9476bb000)
#         libstdc++.so.6 => /cbica/software/external/gcc/centos7/9.4.0/lib64/libstdc++.so.6 (0x00007fa9472e1000)
#         libm.so.6 => /lib64/libm.so.6 (0x00007fa946fdf000)
#         libgcc_s.so.1 => /cbica/software/external/gcc/centos7/9.4.0/lib64/libgcc_s.so.1 (0x00007fa946dc7000)
#         libpthread.so.0 => /lib64/libpthread.so.0 (0x00007fa946bab000)
#         libc.so.6 => /lib64/libc.so.6 (0x00007fa9467dd000)
#         libverify.so => /usr/lib/jvm/java-1.8.0/jre/lib/amd64/libverify.so (0x00007fa9465ce000)
#         libdl.so.2 => /lib64/libdl.so.2 (0x00007fa9463ca000)
#         /lib64/ld-linux-x86-64.so.2 (0x00007fa948c29000)
ldd /venvs/nighres/lib/python3.11/site-packages/jcc/_jcc3.cpython-311-x86_64-linux-gnu.so
nm /venvs/nighres/lib/python3.11/site-packages/jcc/_jcc3.cpython-311-x86_64-linux-gnu.so

# and need to futz with LD_LIBRARY_PATH because who knows why
#export LD_LIBRARY_PATH=/usr/lib/jvm/temurin-8-jdk-amd64/jre/lib/amd64:/usr/lib/jvm/temurin-8-jdk-amd64/jre/lib/amd64/server
#export LD_RUN_PATH=/usr/lib/jvm/temurin-8-jdk-amd64/jre/lib/amd64:/usr/lib/jvm/temurin-8-jdk-amd64/jre/lib/amd64/server

#git clone https://github.com/nighres/nighres /nighres
cd /nighres
./build.sh
python -m pip install . 

%runscript
/neurodocker/startup.sh "$@"

